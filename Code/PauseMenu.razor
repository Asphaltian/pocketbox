@using Sandbox.UI

@namespace sGBA

@inherits PanelComponent

<root class="pause-menu @(IsVisible ? "visible" : "") @(ShowConfirmDialog ? "confirm-open" : "") @(ShowSavingDialog ? "saving-open" : "")">
	<div class="overlay">
		<div class="menu-container">
			<div class="menu-left @(InSlotPanel ? "in-slots" : "")">
				@foreach ( var item in MenuItems )
				{
					<div class="menu-item @(item == SelectedItem ? "selected" : "")"
						 onmouseenter=@( () => SelectItemByName( item ) )
						 onclick=@( () => ActivateItem( item ) )>
						@item
					</div>
				}
			</div>
			<div class="menu-divider @(ShowSlots ? "visible" : "")"></div>
			<div class="menu-right @(ShowSlots ? "visible" : "")">
				@for ( int i = 1; i <= SaveState.SlotCount; i++ )
				{
					var slot = i;
					<div class="slot @(slot == HighlightedSlot && ShowSlots ? "highlighted" : "")"
						 onmouseenter=@( () => HighlightedSlot = slot )
						 onclick=@( () => ActivateSlot( slot ) )>
						<div class="slot-preview">
							@if ( SlotTextures[slot - 1] != null )
							{
								<Image Texture=@SlotTextures[slot - 1] />
							}
							else
							{
								<span>No data.</span>
							}
						</div>
						<div class="slot-info">
							<div class="slot-label">Save slot #@slot</div>
							@if ( SlotTimestamps[slot - 1] != null )
							{
								<div class="slot-timestamp">@SlotTimestamps[slot - 1].Value.ToString( "dd/MM/yyyy - HH:mm" )</div>
							}
						</div>
					</div>
				}
			</div>
		</div>

		<div class="dialog-overlay @(ShowConfirmDialog ? "visible" : "")">
			<div class="confirm-box">
				<div class="dialog-message">Overwrite this data?</div>
				<div class="confirm-buttons">
					<div class="confirm-btn @(ConfirmSelection == 0 ? "selected" : "")"
						 onmouseenter=@( () => ConfirmSelection = 0 )
						 onclick=@( () => ConfirmOverwrite() )>
						Yes
					</div>
					<div class="confirm-btn @(ConfirmSelection == 1 ? "selected" : "")"
						 onmouseenter=@( () => ConfirmSelection = 1 )
						 onclick=@( () => CancelOverwrite() )>
						No
					</div>
				</div>
			</div>
		</div>

		<div class="dialog-overlay @(ShowSavingDialog ? "visible" : "")">
			<div class="dialog-box">
				<div class="dialog-message">Saving...</div>
			</div>
		</div>
	</div>
</root>

@code
{
	private const int MenuContinue = 0;
	private const int MenuLoad = 1;
	private const int MenuCreate = 2;
	private const int MenuControls = 3;
	private const int MenuReset = 4;

	private static readonly string[] MenuItems =
	[
		"Continue",
		"Load Suspend Point",
		"Create Suspend Point",
		"View/Change Controls",
		"Reset Game"
	];

	public bool IsVisible { get; private set; }
	private int SelectedIndex { get; set; }
	private string SelectedItem => MenuItems[SelectedIndex];
	private bool HasSlotPanel => SelectedIndex is MenuLoad or MenuCreate;
	private bool IsLoadMode => SelectedIndex == MenuLoad;

	private bool InSlotPanel { get; set; }
	private int HighlightedSlot { get; set; } = 1;
	private bool ShowSlots => HasSlotPanel;

	private readonly Texture[] SlotTextures = new Texture[SaveState.SlotCount];
	private readonly bool[] SlotOccupied = new bool[SaveState.SlotCount];
	private readonly DateTime?[] SlotTimestamps = new DateTime?[SaveState.SlotCount];
	private int _slotVersion;

	private bool ShowConfirmDialog { get; set; }
	private int ConfirmSelection { get; set; }
	private int _pendingOverwriteSlot;
	private bool ShowSavingDialog { get; set; }

	private bool _useGamepad;
	private const float StickDeadzone = 0.5f;
	private bool _stickUp, _stickDown, _stickLeft, _stickRight;

	private const float RepeatDelay = 0.4f;
	private const float RepeatRate = 0.08f;
	private float _upHoldTime, _upNextRepeat;
	private float _downHoldTime, _downNextRepeat;

	protected override void OnUpdate()
	{
		if ( !EmulatorComponent.Current.IsValid() || !EmulatorComponent.Current.IsReady )
			return;

		if ( Input.EscapePressed )
		{
			Input.EscapePressed = false;

			if ( IsVisible && !new Game.Overlay().IsOpen )
				Resume();
			else if ( !IsVisible )
				Pause();

			return;
		}

		if ( !IsVisible ) return;
		if ( new Game.Overlay().IsOpen ) return;

		if ( ShowConfirmDialog )
		{
			HandleConfirmInput();
			return;
		}

		if ( ShowSavingDialog ) return;

		DetectMouseUsage();
		ReadStickEdges( out var upEdge, out var downEdge, out var leftEdge, out var rightEdge );

		HandleVerticalRepeat( "GBA_Up", upEdge, _stickUp, ref _upHoldTime, ref _upNextRepeat, NavigateUp );
		HandleVerticalRepeat( "GBA_Down", downEdge, _stickDown, ref _downHoldTime, ref _downNextRepeat, NavigateDown );

		if ( Input.Pressed( "GBA_Right" ) || rightEdge )
		{
			if ( !InSlotPanel && HasSlotPanel )
				EnterSlotPanel();
		}

		if ( Input.Pressed( "GBA_Left" ) || leftEdge )
		{
			if ( InSlotPanel )
				ExitSlotPanel();
		}

		if ( Input.Pressed( "GBA_A" ) )
		{
			SetGamepadMode();
			Sound.Play( "ui.button.press" );

			if ( InSlotPanel )
				ActivateSlot( HighlightedSlot );
			else if ( HasSlotPanel )
				EnterSlotPanel();
			else
				ActivateItem( SelectedItem );
		}

		if ( Input.Pressed( "GBA_B" ) )
		{
			SetGamepadMode();
			Sound.Play( "ui.button.press" );

			if ( InSlotPanel )
				ExitSlotPanel();
			else
				Resume();
		}
	}

	private void ReadStickEdges( out bool upEdge, out bool downEdge, out bool leftEdge, out bool rightEdge )
	{
		float sx = Input.GetAnalog( InputAnalog.LeftStickX );
		float sy = Input.GetAnalog( InputAnalog.LeftStickY );

		bool up = sy < -StickDeadzone;
		bool down = sy > StickDeadzone;
		bool left = sx < -StickDeadzone;
		bool right = sx > StickDeadzone;

		upEdge = up && !_stickUp;
		downEdge = down && !_stickDown;
		leftEdge = left && !_stickLeft;
		rightEdge = right && !_stickRight;

		_stickUp = up;
		_stickDown = down;
		_stickLeft = left;
		_stickRight = right;
	}

	private void HandleVerticalRepeat( string action, bool stickEdge, bool stickHeld,
		ref float holdTime, ref float nextRepeat, Action navigate )
	{
		if ( Input.Pressed( action ) || stickEdge )
		{
			holdTime = 0;
			nextRepeat = RepeatDelay;
			navigate();
		}
		else if ( Input.Down( action ) || stickHeld )
		{
			holdTime += Time.Delta;
			if ( holdTime >= nextRepeat )
			{
				nextRepeat += RepeatRate;
				navigate();
			}
		}
		else
		{
			holdTime = 0;
		}
	}

	private void SetGamepadMode()
	{
		_useGamepad = true;
		Mouse.Visibility = MouseVisibility.Hidden;
	}

	private void DetectMouseUsage()
	{
		if ( Mouse.Delta.Length > 5 )
		{
			_useGamepad = false;
			Mouse.Visibility = MouseVisibility.Visible;
		}
	}

	private void NavigateUp()
	{
		SetGamepadMode();
		Sound.Play( "ui.button.over" );

		if ( InSlotPanel )
			HighlightedSlot = HighlightedSlot <= 1 ? SaveState.SlotCount : HighlightedSlot - 1;
		else
			SelectedIndex = SelectedIndex <= 0 ? MenuItems.Length - 1 : SelectedIndex - 1;
	}

	private void NavigateDown()
	{
		SetGamepadMode();
		Sound.Play( "ui.button.over" );

		if ( InSlotPanel )
			HighlightedSlot = HighlightedSlot >= SaveState.SlotCount ? 1 : HighlightedSlot + 1;
		else
			SelectedIndex = SelectedIndex >= MenuItems.Length - 1 ? 0 : SelectedIndex + 1;
	}

	private void EnterSlotPanel()
	{
		SetGamepadMode();
		Sound.Play( "ui.button.press" );
		InSlotPanel = true;
		HighlightedSlot = 1;
	}

	private void ExitSlotPanel()
	{
		SetGamepadMode();
		Sound.Play( "ui.button.press" );
		InSlotPanel = false;
	}

	private void Pause()
	{
		IsVisible = true;
		SelectedIndex = 0;
		InSlotPanel = false;
		HighlightedSlot = 1;
		_stickUp = _stickDown = _stickLeft = _stickRight = false;
		SetGamepadMode();
		Sound.Play( "ui.popup.message.open" );
		EmulatorComponent.Current.SetPaused( true );
		RefreshSlotPreviews();
	}

	private void Resume()
	{
		IsVisible = false;
		SelectedIndex = MenuContinue;
		InSlotPanel = false;
		Mouse.Visibility = MouseVisibility.Hidden;
		Sound.Play( "ui.popup.message.close" );
		EmulatorComponent.Current.SetPaused( false );
	}

	private void SelectItemByName( string item )
	{
		SelectedIndex = Array.IndexOf( MenuItems, item );
		InSlotPanel = false;
		if ( HasSlotPanel )
			HighlightedSlot = 1;
	}

	private void ActivateItem( string item )
	{
		switch ( item )
		{
			case "Continue":
				Resume();
				break;
			case "Load Suspend Point":
			case "Create Suspend Point":
				SelectItemByName( item );
				InSlotPanel = true;
				HighlightedSlot = 1;
				break;
			case "View/Change Controls":
				Game.Overlay.ShowBinds();
				break;
			case "Reset Game":
				EmulatorComponent.Current.ResetEmulator();
				Resume();
				break;
		}
	}

	private void ActivateSlot( int slot )
	{
		if ( IsLoadMode )
		{
			if ( !SlotOccupied[slot - 1] )
				return;

			EmulatorComponent.Current.LoadSuspendPoint( slot );
			Resume();
		}
		else
		{
			if ( SlotOccupied[slot - 1] )
			{
				_pendingOverwriteSlot = slot;
				ConfirmSelection = 0;
				ShowConfirmDialog = true;
				Sound.Play( "ui.popup.message.open" );
				return;
			}

			DoSave( slot );
		}
	}

	private void HandleConfirmInput()
	{
		float sy = Input.GetAnalog( InputAnalog.LeftStickY );
		bool up = sy < -StickDeadzone;
		bool down = sy > StickDeadzone;
		bool upEdge = up && !_stickUp;
		bool downEdge = down && !_stickDown;
		_stickUp = up;
		_stickDown = down;

		if ( Input.Pressed( "GBA_Up" ) || upEdge || Input.Pressed( "GBA_Down" ) || downEdge )
		{
			SetGamepadMode();
			Sound.Play( "ui.button.over" );
			ConfirmSelection = ConfirmSelection == 0 ? 1 : 0;
		}

		if ( Input.Pressed( "GBA_A" ) )
		{
			SetGamepadMode();
			Sound.Play( "ui.button.press" );

			if ( ConfirmSelection == 0 )
				ConfirmOverwrite();
			else
				CancelOverwrite();
		}

		if ( Input.Pressed( "GBA_B" ) )
		{
			SetGamepadMode();
			Sound.Play( "ui.button.press" );
			CancelOverwrite();
		}

		DetectMouseUsage();
	}

	private void ConfirmOverwrite()
	{
		ShowConfirmDialog = false;
		DoSave( _pendingOverwriteSlot );
	}

	private void CancelOverwrite()
	{
		ShowConfirmDialog = false;
		Sound.Play( "ui.popup.message.close" );
	}

	private async void DoSave( int slot )
	{
		ShowSavingDialog = true;
		await Task.Delay( 100 );
		EmulatorComponent.Current.CreateSuspendPoint( slot );
		RefreshSlotPreviews();
		await Task.Delay( 500 );
		ShowSavingDialog = false;
	}

	private void RefreshSlotPreviews()
	{
		var emu = EmulatorComponent.Current;
		if ( !emu.IsValid() ) return;

		for ( int i = 0; i < SaveState.SlotCount; i++ )
		{
			var path = emu.GetStatePath( i + 1 );

			if ( !FileSystem.Data.FileExists( path ) )
			{
				ClearSlot( i );
				continue;
			}

			var data = FileSystem.Data.ReadAllBytes( path ).ToArray();
			SlotOccupied[i] = true;
			SlotTimestamps[i] = SaveState.ReadTimestamp( data );

			var screenshot = SaveState.ReadScreenshot( data );
			if ( screenshot == null ) continue;

			if ( SlotTextures[i] == null )
			{
				SlotTextures[i] = Texture.Create( GbaConstants.ScreenWidth, GbaConstants.ScreenHeight, ImageFormat.RGBA8888 )
					.WithDynamicUsage()
					.WithName( $"suspend-preview-{i}" )
					.Finish();
			}

			SlotTextures[i].Update( screenshot, 0, 0, GbaConstants.ScreenWidth, GbaConstants.ScreenHeight );
		}

		_slotVersion++;
	}

	private void ClearSlot( int index )
	{
		SlotOccupied[index] = false;
		SlotTimestamps[index] = null;
		SlotTextures[index]?.Dispose();
		SlotTextures[index] = null;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			IsVisible, SelectedIndex, InSlotPanel, HighlightedSlot,
			_useGamepad, _slotVersion, ShowConfirmDialog,
			HashCode.Combine( ConfirmSelection, ShowSavingDialog )
		);
	}

	protected override void OnDestroy()
	{
		for ( int i = 0; i < SlotTextures.Length; i++ )
		{
			SlotTextures[i]?.Dispose();
			SlotTextures[i] = null;
		}
	}
}
